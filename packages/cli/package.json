{
	"name": "@ctx/cli",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"bin": {
		"ctx": "./src/index.ts",
		"ctx-mcp": "./src/mcp.ts"
	},
	"scripts": {
		"dev": "bun run src/index.ts",
		"mcp": "bun run src/mcp.ts",
		"build": "bun build --compile src/index.ts --outfile dist/ctx && bun build --compile src/mcp.ts --outfile dist/ctx-mcp",
		"install:bin": "bun run build && cp dist/ctx dist/ctx-mcp /usr/local/bin/",
		"clean": "rm -rf dist",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0",
		"commander": "^13.0.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.12",
		"typescript": "^6.0.3"
	}
}
